{
  "name": "i-am-boss",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "harness": "tsx src/harness/run.ts",
    "balance": "tsx src/harness/balance.ts",
    "probability:audit": "tsx src/harness/probability-audit.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.13.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.3.5",
    "vitest": "^3.0.9"
  }
}
